{
  "id": "memory.recall",
  "version": "0.1.0",
  "description": "Recall a remembered fact by key.",
  "params_schema": {
    "type": "object",
    "properties": {
      "key": { "type": "string", "minLength": 1 }
    },
    "required": ["key"],
    "additionalProperties": false
  },
  "permissions": ["Memory"],
  "risk": "Safe",
  "examples": ["recall project.root", "what is my projects folder", "remembered user.name", "вспомни user.name"],
  "triggers": [
    { "pattern": "(?i)^recall (?P<key>.+)$" },
    { "pattern": "(?i)^вспомни (?P<key>.+)$" }
  ]
}
